# ──────────────────────────────────────────────────
# Personas Agentes — Environment Variables
# Copy this file to .env and adjust values as needed.
# ──────────────────────────────────────────────────

# ── Runtime Mode ──────────────────────────────────
# Set to "production" to silence verbose logging and enable minified outputs.
NODE_ENV=development

# Set to "1" to run diagnostics in test-only mode (no side-effects).
DIAGNOSTIC_TEST_MODE=0

# ── gRPC Native Services ─────────────────────────
# Go Hub Proxy — filesystem watcher + task queue.
HUB_GRPC_HOST=localhost:50051

# Rust Analyzer Sidecar — AST analysis, fingerprint, auditing.
ANALYZER_GRPC_HOST=localhost:50052

# ── Logging ───────────────────────────────────────
# Winston log level: error | warn | info | debug
LOG_LEVEL=info
